{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,               // Désactive la surveillance stricte
    "noImplicitAny": false,        // Autorise les variables sans type (comme ton 'cb' ou 'req')
    "skipLibCheck": true,          // Ignore les erreurs dans les bibliothèques externes
    "esModuleInterop": true
  },
  "include": ["src"]
}